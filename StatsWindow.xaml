<Window x:Class="NetSpeedMonitor.StatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Data Usage" Height="520" Width="640"
        Background="#1D2326" Foreground="White" WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#252C30"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" Background="#252C30" BorderBrush="#333" BorderThickness="1,1,1,0"
                                Padding="{TemplateBinding Padding}" Margin="0,0,2,0">
                            <ContentPresenter x:Name="ContentSite" ContentSource="Header" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#333C40"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2E363B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="#252C30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border Name="Border" Background="#252C30" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2E3A40"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1F4E6B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GvHeader" TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#333C40"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Data Usage Statistics" FontSize="18" FontWeight="Bold" Foreground="#33AAFF" Margin="0,0,0,10"/>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Session" Foreground="#888888" FontSize="11"/>
                <TextBlock x:Name="TxtSession" Text="-" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
                <TextBlock Text="Today" Foreground="#888888" FontSize="11"/>
                <TextBlock x:Name="TxtToday" Text="-" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="All Time" Foreground="#888888" FontSize="11"/>
                <TextBlock x:Name="TxtTotal" Text="-" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </Grid>

        <TabControl Grid.Row="2" Background="#252C30" BorderBrush="#333">
            <TabItem Header="Last 24 Hours">
                <ListView x:Name="LvHours" Background="#252C30" Foreground="White" BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn HeaderContainerStyle="{StaticResource GvHeader}" Header="Hour" Width="160" DisplayMemberBinding="{Binding Key}"/>
                            <GridViewColumn HeaderContainerStyle="{StaticResource GvHeader}" Header="Upload" Width="120" DisplayMemberBinding="{Binding Up}"/>
                            <GridViewColumn HeaderContainerStyle="{StaticResource GvHeader}" Header="Download" Width="120" DisplayMemberBinding="{Binding Down}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>
            <TabItem Header="Last 30 Days">
                <ListView x:Name="LvDays" Background="#252C30" Foreground="White" BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn HeaderContainerStyle="{StaticResource GvHeader}" Header="Day" Width="160" DisplayMemberBinding="{Binding Key}"/>
                            <GridViewColumn HeaderContainerStyle="{StaticResource GvHeader}" Header="Upload" Width="120" DisplayMemberBinding="{Binding Up}"/>
                            <GridViewColumn HeaderContainerStyle="{StaticResource GvHeader}" Header="Download" Width="120" DisplayMemberBinding="{Binding Down}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Clear All Data" Background="#5C2A2A" Foreground="White" FontWeight="Bold" BorderBrush="#8A3333" BorderThickness="1" Height="28" Width="110" Margin="0,0,8,0" Click="Clear_Click"/>
            <Button Content="Refresh" Background="#33AAFF" Foreground="Black" FontWeight="Bold" BorderThickness="0" Height="28" Width="90" Margin="0,0,8,0" Click="Refresh_Click"/>
            <Button Content="Close" Background="#444" Foreground="White" FontWeight="Bold" BorderThickness="0" Height="28" Width="90" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
