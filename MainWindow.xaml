<Window x:Class="NetSpeedMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetSpeed" WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        MouseDown="Window_MouseDown" Closing="Window_Closing" Loaded="Window_Loaded">

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Settings" Click="Settings_Click"/>
            <MenuItem Header="Data Usage..." Click="Stats_Click"/>
            <Separator/>
            <MenuItem Header="Reset Session Stats" Click="ResetSession_Click"/>
            <Separator/>
            <MenuItem Header="Exit" Click="Exit_Click"/>
        </ContextMenu>
    </Window.ContextMenu>

    <Border x:Name="MainBorder" Background="#01000000" CornerRadius="6" BorderBrush="#33FFFFFF" BorderThickness="1" Padding="8,2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel x:Name="UpRow" Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="UpIcon" Text="\u2191" Foreground="#FFAA33" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,3,0"/>
                <TextBlock x:Name="UpText" Text="0 B/s" Foreground="#FFAA33" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel x:Name="DownRow" Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="DownIcon" Text="\u2193" Foreground="#33AAFF" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,3,0"/>
                <TextBlock x:Name="DownText" Text="0 B/s" Foreground="#33AAFF" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
