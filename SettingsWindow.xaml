<Window x:Class="NetSpeedMonitor.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Net Speed Settings" Height="720" Width="380"
        Background="#1D2326" Foreground="White" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="ValLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#33AAFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="55"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
        </Style>
        <Style x:Key="SliderRow" TargetType="DockPanel">
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2A3236"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2A3236"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#33AAFF"/>
        </Style>
        <Style x:Key="BtnDark" TargetType="Button">
            <Setter Property="Background" Value="#333C40"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#888888"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Net Speed Monitor" FontSize="18" FontWeight="Bold" Foreground="#33AAFF" Margin="0,0,0,10"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
            <StackPanel>

                <CheckBox x:Name="ChkHideFullScreen" Content="Auto-Hide in Fullscreen" Click="SettingChanged"/>

                <TextBlock Text="--- Window &amp; Layout ---" Style="{StaticResource SectionHeader}"/>
                <TextBlock Text="Widget Width (px)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtWidth" TextChanged="SettingChanged"/>
                <TextBlock Text="Widget Height (px)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtHeight" TextChanged="SettingChanged"/>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,8">
                    <Button x:Name="BtnCenterH" Style="{StaticResource BtnDark}" Content="Center Horizontally" Click="CenterH_Click"/>
                    <Button x:Name="BtnCenterV" Style="{StaticResource BtnDark}" Content="Center Vertically" Click="CenterV_Click"/>
                </StackPanel>
                <TextBlock Text="Horizontal Padding (px)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtPadding" TextChanged="SettingChanged"/>
                <TextBlock Text="Vertical Padding (px)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtVPadding" TextChanged="SettingChanged"/>
                <TextBlock Text="Row Spacing (px)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtRowSpacing" TextChanged="SettingChanged"/>
                <TextBlock Text="Corner Radius (px)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtRadius" TextChanged="SettingChanged"/>
                <CheckBox x:Name="ChkShowBorder" Content="Show Border" Click="SettingChanged"/>
                <TextBlock Text="Border Thickness (px)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtBorderThickness" TextChanged="SettingChanged"/>
                <TextBlock Text="Border Hex Color" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtBorderColor" TextChanged="SettingChanged"/>
                <TextBlock Text="Background Opacity (1-255)" Style="{StaticResource FieldLabel}"/>
                <DockPanel Style="{StaticResource SliderRow}">
                    <TextBlock x:Name="LblAlpha" Style="{StaticResource ValLabel}" DockPanel.Dock="Right"/>
                    <Slider x:Name="AlphaSlider" Minimum="1" Maximum="255" ValueChanged="SettingChanged"/>
                </DockPanel>

                <TextBlock Text="--- Sampling &amp; Units ---" Style="{StaticResource SectionHeader}"/>
                <TextBlock Text="Sample Interval (ms)" Style="{StaticResource FieldLabel}"/>
                <DockPanel Style="{StaticResource SliderRow}">
                    <TextBlock x:Name="LblInterval" Style="{StaticResource ValLabel}" DockPanel.Dock="Right"/>
                    <Slider x:Name="SldInterval" Minimum="250" Maximum="5000" TickFrequency="250" IsSnapToTickEnabled="True" ValueChanged="SettingChanged"/>
                </DockPanel>
                <TextBlock Text="Smoothing (1 = instant, higher = smoother)" Style="{StaticResource FieldLabel}"/>
                <DockPanel Style="{StaticResource SliderRow}">
                    <TextBlock x:Name="LblSmoothing" Style="{StaticResource ValLabel}" DockPanel.Dock="Right"/>
                    <Slider x:Name="SldSmoothing" Minimum="1" Maximum="60" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="SettingChanged"/>
                </DockPanel>
                <TextBlock Text="Unit Base" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="CmbUnitBase" SelectionChanged="SettingChanged">
                    <ComboBoxItem Content="Bytes (B)"/>
                    <ComboBoxItem Content="Bits (b)"/>
                </ComboBox>
                <TextBlock Text="Unit System" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="CmbUnit" SelectionChanged="SettingChanged">
                    <ComboBoxItem Content="Binary (KiB/MiB)"/>
                    <ComboBoxItem Content="Decimal (KB/MB)"/>
                </ComboBox>
                <TextBlock Text="Decimal Places" Style="{StaticResource FieldLabel}"/>
                <DockPanel Style="{StaticResource SliderRow}">
                    <TextBlock x:Name="LblDecimals" Style="{StaticResource ValLabel}" DockPanel.Dock="Right"/>
                    <Slider x:Name="SldDecimals" Minimum="0" Maximum="3" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="SettingChanged"/>
                </DockPanel>
                <CheckBox x:Name="ChkShowSuffix" Content="Show Unit Suffix (e.g. MB/s)" Click="SettingChanged"/>
                <CheckBox x:Name="ChkMinUnitKB" Content="Minimum Unit = KB (never show B)" Click="SettingChanged"/>
                <CheckBox x:Name="ChkSwapUpDown" Content="Swap Up/Down Rows" Click="SettingChanged" Margin="0,0,0,10"/>

                <TextBlock Text="--- Fonts &amp; Icons ---" Style="{StaticResource SectionHeader}"/>
                <TextBlock Text="Font Family" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtFont" TextChanged="SettingChanged"/>
                <TextBlock Text="Font Size" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtFontSize" TextChanged="SettingChanged"/>
                <CheckBox x:Name="ChkBold" Content="Bold Text" Click="SettingChanged"/>
                <CheckBox x:Name="ChkShowIcons" Content="Show Direction Icons" Click="SettingChanged"/>
                <TextBlock Text="Upload Icon (char)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtUpIcon" TextChanged="SettingChanged"/>
                <TextBlock Text="Download Icon (char)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtDownIcon" TextChanged="SettingChanged"/>
                <TextBlock Text="Upload Text Color (hex)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtUpColor" TextChanged="SettingChanged"/>
                <TextBlock Text="Download Text Color (hex)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtDownColor" TextChanged="SettingChanged"/>
                <TextBlock Text="Upload Icon Color (hex, blank = match text)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtUpIconColor" TextChanged="SettingChanged"/>
                <TextBlock Text="Download Icon Color (hex, blank = match text)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtDownIconColor" TextChanged="SettingChanged" Margin="0,0,0,10"/>

                <TextBlock Text="--- Adapter ---" Style="{StaticResource SectionHeader}"/>
                <TextBlock Text="Adapter Mode" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="CmbAdapterMode" SelectionChanged="AdapterModeChanged">
                    <ComboBoxItem Content="Auto (default route, VPN-aware)"/>
                    <ComboBoxItem Content="All (sum all adapters)"/>
                    <ComboBoxItem Content="Manual (pick adapter)"/>
                </ComboBox>
                <TextBlock Text="Manual Adapter" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="CmbAdapter" SelectionChanged="SettingChanged" Margin="0,0,0,10"/>

                <TextBlock Text="--- Data Usage Stats ---" Style="{StaticResource SectionHeader}"/>
                <CheckBox x:Name="ChkStatsEnabled" Content="Enable Data Usage Tracking" Click="SettingChanged"/>
                <CheckBox x:Name="ChkTooltip" Content="Show Session/Total in Tooltip" Click="SettingChanged"/>
                <TextBlock Text="Disk Flush Interval (minutes)" Style="{StaticResource FieldLabel}"/>
                <DockPanel Style="{StaticResource SliderRow}">
                    <TextBlock x:Name="LblFlush" Style="{StaticResource ValLabel}" DockPanel.Dock="Right"/>
                    <Slider x:Name="SldFlush" Minimum="1" Maximum="60" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="SettingChanged"/>
                </DockPanel>
                <TextBlock Text="Retention (days)" Style="{StaticResource FieldLabel}"/>
                <DockPanel Style="{StaticResource SliderRow}">
                    <TextBlock x:Name="LblRetention" Style="{StaticResource ValLabel}" DockPanel.Dock="Right"/>
                    <Slider x:Name="SldRetention" Minimum="1" Maximum="365" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="SettingChanged"/>
                </DockPanel>
                <Button x:Name="BtnClearData" Style="{StaticResource BtnDark}" Content="Clear All Usage Data" Click="ClearData_Click" Margin="0,8,0,10" Height="30" Background="#5C2A2A" BorderBrush="#8A3333"/>

            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2" Content="Save &amp; Close" Background="#33AAFF" Foreground="Black" FontWeight="Bold" BorderThickness="0" Height="30" Margin="0,15,0,0" Click="Close_Click"/>
    </Grid>
</Window>
